# Environment variables for Quran Shield
# Copy this to .env and modify as needed

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False

# ============================================================================
# CORS Settings (comma-separated origins)
# ============================================================================
# ⚠️ IMPORTANT FOR PRODUCTION:
#    The default "*" allows ALL origins, which is a security risk.
#    Set this to your actual domain(s) before deploying to production.
#
# Examples:
#   Development:  CORS_ORIGINS=*
#   Production:   CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# ============================================================================
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO

# Audio Processing
MAX_FILE_SIZE_MB=50
